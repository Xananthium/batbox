# BatBox environment configuration — copy to ~/.batbox/.env and uncomment the section that fits.
# Mix-and-match: any OpenAI-compatible endpoint works. The BATBOX_* names matter — they are NOT OPENAI_*.
#
# Usage:
#   1. Pick the backend section below that matches your setup.
#   2. Uncomment those lines and fill in any REPLACE_WITH_* placeholders.
#   3. Copy the result to ~/.batbox/.env
#   4. Add any "Common settings" you want at the bottom.

# ---------------------------------------------------------------
# Example 1 — Local Ollama (CLI)
# ---------------------------------------------------------------
# Best for: offline-capable dev. Requires `ollama serve` running locally.
# Run `ollama pull llama3.1:8b` first.
#
# BATBOX_API_BASE_URL=http://localhost:11434/v1
# BATBOX_API_KEY=ollama
# BATBOX_DEFAULT_MODEL=llama3.1:8b
# BATBOX_MODELS=llama3.1:8b,qwen2.5-coder:7b,mistral:7b

# ---------------------------------------------------------------
# Example 2 — Ollama Cloud (routed through local Ollama)
# ---------------------------------------------------------------
# Best for: top-tier models without paying per-token. Requires `ollama signin`
# and `ollama pull <model>:cloud` to register routes. Frontier-quality cloud
# inference through the local Ollama proxy.
#
# BATBOX_API_BASE_URL=http://localhost:11434/v1
# BATBOX_API_KEY=ollama
# BATBOX_DEFAULT_MODEL=qwen3-coder:480b-cloud
# BATBOX_MODELS=qwen3-coder:480b-cloud,deepseek-v4-flash:cloud,kimi-k2.6:cloud,glm-5:cloud,nemotron-3-super:cloud

# ---------------------------------------------------------------
# Example 3 — LM Studio (local GGUF inference)
# ---------------------------------------------------------------
# Best for: running quantized models on Apple Silicon / Linux GPU.
# Start LM Studio server on the default port. Avoid -mlx tagged models if you
# hit stability issues — vanilla GGUF is more reliable for streaming.
#
# BATBOX_API_BASE_URL=http://localhost:1234/v1
# BATBOX_API_KEY=lm-studio
# BATBOX_DEFAULT_MODEL=qwen2.5-coder-7b-instruct
# BATBOX_MODELS=qwen2.5-coder-7b-instruct,llama-3.1-8b-instruct

# ---------------------------------------------------------------
# Example 4 — OpenAI direct
# ---------------------------------------------------------------
# Best for: GPT-4 family. Costs per token. Replace the key.
#
# BATBOX_API_BASE_URL=https://api.openai.com/v1
# BATBOX_API_KEY=sk-proj-REPLACE_WITH_YOUR_KEY
# BATBOX_DEFAULT_MODEL=gpt-4o
# BATBOX_MODELS=gpt-4o,gpt-4o-mini,gpt-4.1,gpt-4.1-mini

# ---------------------------------------------------------------
# Example 5 — DeepSeek direct
# ---------------------------------------------------------------
# Best for: cheap reasoning. DeepSeek V4 Flash has a non-standard `thinking`
# param that's safely ignored by OpenAI-compat clients.
#
# BATBOX_API_BASE_URL=https://api.deepseek.com
# BATBOX_API_KEY=REPLACE_WITH_DEEPSEEK_API_KEY
# BATBOX_DEFAULT_MODEL=deepseek-v4-flash
# BATBOX_MODELS=deepseek-v4-flash,deepseek-chat

# ---------------------------------------------------------------
# Example 6 — Moonshot / Kimi K2 direct
# ---------------------------------------------------------------
# Best for: massive context (262K). Watch max_tokens — don't exceed
# remaining context or the API returns 400.
#
# BATBOX_API_BASE_URL=https://api.moonshot.ai/v1
# BATBOX_API_KEY=REPLACE_WITH_MOONSHOT_API_KEY
# BATBOX_DEFAULT_MODEL=kimi-k2.6
# BATBOX_MODELS=kimi-k2.6,moonshot-v1-128k

# ---------------------------------------------------------------
# Example 7 — OpenRouter (any model, single key)
# ---------------------------------------------------------------
# Best for: trying many models without setting up multiple accounts.
# Costs per token. Model names use vendor/ prefix.
#
# BATBOX_API_BASE_URL=https://openrouter.ai/v1
# BATBOX_API_KEY=sk-or-v1-REPLACE_WITH_OPENROUTER_KEY
# BATBOX_DEFAULT_MODEL=anthropic/claude-opus-4-7
# BATBOX_MODELS=anthropic/claude-opus-4-7,openai/gpt-4o,google/gemini-2.5-pro,deepseek/deepseek-v4-flash

# ---------------------------------------------------------------
# Common settings (apply to any backend above)
# ---------------------------------------------------------------
# Tier aliases — tools that ask for "opus"/"sonnet"/"haiku" map here.
# Set all three to your strongest model if you don't care about tiers.
#
# BATBOX_OPUS_MODEL=qwen3-coder:480b-cloud
# BATBOX_SONNET_MODEL=qwen3-coder:480b-cloud
# BATBOX_HAIKU_MODEL=qwen3-coder:480b-cloud
#
# Tuning — bump max_tokens for reasoning models with long thinking chains.
# BATBOX_MAX_TOKENS=8192
# BATBOX_TEMPERATURE=0.2
#
# Python sidecar (web scraping via Scrapling)
# BATBOX_SIDECAR_PORT=8823
# BATBOX_SIDECAR_DISABLE=0
